#!/bin/bash
# fbox-memory-delete: Delete a memory entry (IRREVERSIBLE)
# Usage: fbox-memory-delete <namespace> <key> [agent]
NS="${1}"
KEY="${2}"
AGENT="${3:-curator}"
curl -s -X DELETE "http://localhost:8080/v1/sanctum/memory/${NS}/${KEY}" \
  -H "Authorization: Bearer dev-key-change-in-production" \
  -H "X-Agent-ID: ${AGENT}"

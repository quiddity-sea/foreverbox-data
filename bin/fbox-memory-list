#!/bin/bash
# fbox-memory-list: List entries in a namespace
# Usage: fbox-memory-list <namespace> [limit] [agent]
NS="${1:-memory}"
LIMIT="${2:-20}"
AGENT="${3:-curator}"
curl -s "http://localhost:8080/v1/sanctum/memory?namespace=${NS}&limit=${LIMIT}" \
  -H "Authorization: Bearer dev-key-change-in-production" \
  -H "X-Agent-ID: ${AGENT}"
